# ── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── External APIs ─────────────────────────────────────────────────────────
NEWS_API_KEY=your-newsapi-key           # https://newsapi.org
GROQ_API_KEY=your-groq-api-key         # https://console.groq.com

# ── Upstash Redis (response caching + training rate limit/lock) ───────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── ML Training ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
TRAIN_API_KEY=your-train-api-key
# URL from `modal deploy modal/modal_app.py` output
MODAL_TRAIN_URL=https://your-workspace--trad-ding-training-train.modal.run
